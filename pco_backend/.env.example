# Application
ENV=dev
APP_NAME=psi-chi-omega-api
APP_VERSION=0.1.0
CORS_ORIGINS=http://localhost:3000

# Database
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/pco

# Authentication — JWT_SECRET is REQUIRED (minimum 32 characters)
JWT_SECRET=your-jwt-secret-minimum-32-characters-here
JWT_ALG=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30

# Supabase Storage (required for event PDF upload/delete)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-supabase-service-role-key

# SMTP Email (required for welcome and confirmation emails)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your-email@example.com
SMTP_PASSWORD=your-smtp-password

# Frontend
FRONTEND_URL=http://localhost:3000
